{
  "name": "the-content-architecture",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.6.2"
  },
  "browserslist": [
    ">0.3%",
    "not dead"
  ],
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  },
  "scripts": {
    "clear": "rm -rf .next && rm -rf node_modules/.cache",
    "plop": "plop",
    "check.types": "tsc --noEmit -p tsconfig.json",
    "check.biome": "biome lint --diagnostic-level=error --no-errors-on-unmatched --files-ignore-unknown=true",
    "check": "concurrently npm:check.*",
    "test": "node --import=tsx --test \"scripts/**/*.test.ts\"",
    "format": "biome check --write --unsafe",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "sanity:typegen": "dotenvx run -- sh -c \"sanity schema extract --path='sanity-schema.json' && sanity typegen generate && sed -i.bak 's/| null/| undefined/g; s/null |/undefined |/g; s/{} |//g; s/| {}//g' sanity/types.ts && rm sanity/types.ts.bak\"",
    "sanity:cli": "dotenvx run -- sanity",
    "sanity:dataset-export": "dotenvx run -- node --import=tsx scripts/sanity-dataset/export.ts",
    "sanity:dataset-import": "dotenvx run -- node --import=tsx scripts/sanity-dataset/import.ts",
    "sanity:dataset-migrate": "dotenvx run -- node --import=tsx scripts/sanity-dataset/migrate.ts",
    "sanity:project-setup": "dotenvx run --ignore=MISSING_ENV_FILE -- node --import=tsx scripts/sanity-project-setup/setup.ts"
  },
  "dependencies": {
    "@activetheory/split-text": "1.1.2",
    "@dotenvx/dotenvx": "1.71.3",
    "@lottiefiles/dotlottie-react": "0.19.4",
    "@mantine/hooks": "9.3.1",
    "@mux/mux-player-react": "3.13.0",
    "@radix-ui/react-compose-refs": "1.1.3",
    "@rive-app/canvas-advanced-single": "2.38.1",
    "@rive-app/react-canvas": "4.29.1",
    "@sanity/vision": "6.0.0",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tailwindcss/postcss": "4.3.1",
    "babel-plugin-react-compiler": "1.0.0",
    "change-case": "5.4.4",
    "cva": "1.0.0-beta.4",
    "geist": "1.7.2",
    "gsap": "3.15.0",
    "lenis": "1.3.23",
    "lil-gui": "0.21.0",
    "motion": "12.40.0",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "next-sanity": "13.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "6.12.4",
    "sanity": "6.0.0",
    "sanity-plugin-media": "4.3.1",
    "sanity-plugin-mux-input": "3.0.0",
    "schema-dts": "2.0.0",
    "tailwind-merge": "3.6.0",
    "three": "0.184.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@sanity/cli": "^7.2.3",
    "@svgr/webpack": "8.1.0",
    "@types/negotiator": "0.6.4",
    "@types/node": "25.9.3",
    "@types/prompts": "2.4.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "commander": "15.0.0",
    "concurrently": "10.0.3",
    "lefthook": "2.1.9",
    "lint-staged": "17.0.7",
    "ora": "9.4.0",
    "plop": "4.0.5",
    "postcss": "8.5.15",
    "prompts": "2.4.2",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
